# PostgreSQL (nuevo stack)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/nico_reparaciones_next?schema=public"

# JWT/Auth (NestJS)
JWT_ACCESS_SECRET="cambiar-por-uno-largo"
JWT_REFRESH_SECRET="cambiar-por-uno-largo"
GOOGLE_OAUTH_ENABLED="0"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# Opcional. Si queda vacio usa ${API_URL}/api/auth/google/callback
GOOGLE_OAUTH_REDIRECT_URI=""

# App URLs
WEB_URL="http://localhost:5174"
API_URL="http://localhost:3001"
VITE_API_URL="http://localhost:3001"
# Base opcional para imagenes heredadas (Laravel/storage)
STORE_IMAGE_BASE_URL="http://127.0.0.1:8000"

# Seguridad / CORS (opcional)
# Lista separada por comas. Si queda vacio, permite todos los origenes (dev).
CORS_ORIGINS="http://localhost:5174,http://127.0.0.1:5174"

# WhatsApp Cloud API (Meta)
WHATSAPP_CLOUD_ENABLED="0"
WHATSAPP_CLOUD_ACCESS_TOKEN=""
WHATSAPP_CLOUD_PHONE_NUMBER_ID=""
WHATSAPP_CLOUD_VERIFY_TOKEN=""
WHATSAPP_CLOUD_API_VERSION="v23.0"
# Solo para pruebas/locales; no usar en produccion salvo proxy controlado.
WHATSAPP_CLOUD_BASE_URL="https://graph.facebook.com"
