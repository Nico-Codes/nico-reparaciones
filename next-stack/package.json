{
  "name": "nico-reparaciones-next-stack",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @nico/api & npm run dev --workspace @nico/web",
    "dev:api": "npm run dev --workspace @nico/api",
    "dev:web": "npm run dev --workspace @nico/web",
    "test": "npm run test --workspaces --if-present",
    "start:prod:api": "npm run start:prod --workspace @nico/api",
    "start:prod:web": "npm run preview:prod --workspace @nico/web",
    "qa": "npm run typecheck && npm run build",
    "qa:preprod": "npm run deploy:check && npm run qa && npm run smoke:web",
    "qa:full": "npm run env:check && npm run qa:backend:full && npm run qa:frontend:e2e && npm run qa:admin:visual && npm run smoke:web",
    "qa:frontend:e2e": "node ./scripts/qa/qa-frontend-e2e.mjs",
    "qa:backend:full": "node ./scripts/qa/qa-backend-full.mjs",
    "qa:route-parity": "node ./scripts/qa/qa-route-parity.mjs",
    "qa:admin:visual": "node ./scripts/qa/qa-admin-visual-audit.mjs",
    "qa:responsive:visual": "node ./scripts/qa/qa-responsive-visual.mjs",
    "qa:legacy:detach": "node ./scripts/qa/qa-legacy-detach.mjs",
    "qa:migration:close": "npm run env:check && npm run deploy:check && npm run qa:backend:full && npm run qa:route-parity && npm run qa:frontend:e2e && npm run qa:admin:visual && npm run qa:responsive:visual && npm run qa:legacy:detach",
    "smoke:web": "node ./scripts/smoke/smoke-web.mjs",
    "env:check": "node ./scripts/checks/env-check.mjs",
    "deploy:check": "node ./scripts/checks/deploy-check.mjs",
    "smoke:api": "node ./scripts/smoke/smoke-api.mjs",
    "smoke:backend": "node ./scripts/smoke/smoke-backend.mjs",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "db:generate": "npm run db:generate --workspace @nico/api",
    "db:check": "npm run db:check --workspace @nico/api",
    "db:migrate": "npm run db:migrate --workspace @nico/api",
    "db:migrate:dev": "npm run db:migrate:dev --workspace @nico/api",
    "db:migrate:deploy": "npm run db:migrate:deploy --workspace @nico/api",
    "db:push": "npm run db:push --workspace @nico/api",
    "db:push:skip-generate": "npm run db:push:skip-generate --workspace @nico/api",
    "db:studio": "npm run db:studio --workspace @nico/api",
    "db:seed": "npm run db:seed --workspace @nico/api",
    "db:seed:demo": "npm run db:seed:demo --workspace @nico/api"
  },
  "devDependencies": {
    "playwright": "^1.58.2",
    "vitest": "^3.2.4"
  }
}
