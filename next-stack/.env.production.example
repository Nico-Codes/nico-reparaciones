# PostgreSQL (producción / staging)
DATABASE_URL="postgresql://USUARIO:CLAVE@HOST:5432/nico_reparaciones_next?schema=public"

# JWT/Auth (NestJS) - usar secretos largos y únicos (32+ chars)
JWT_ACCESS_SECRET="REEMPLAZAR_CON_SECRET_LARGO_Y_UNICO_32+"
JWT_REFRESH_SECRET="REEMPLAZAR_CON_SECRET_LARGO_Y_UNICO_32+"
GOOGLE_OAUTH_ENABLED="0"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# Opcional. Si queda vacio usa ${API_URL}/api/auth/google/callback
GOOGLE_OAUTH_REDIRECT_URI=""
APPLE_SIGNIN_ENABLED="0"
APPLE_CLIENT_ID=""
APPLE_TEAM_ID=""
APPLE_KEY_ID=""
# Soporta saltos de linea escapados con \\n
APPLE_PRIVATE_KEY=""
# Opcional. Si queda vacio usa ${API_URL}/api/auth/apple/callback
APPLE_SIGNIN_REDIRECT_URI=""

# URLs reales (usar HTTPS)
WEB_URL="https://tu-dominio.com"
API_URL="https://api.tu-dominio.com"
VITE_API_URL="https://api.tu-dominio.com"
STORE_IMAGE_BASE_URL="https://tu-dominio.com"
HOST="0.0.0.0"
PORT="3001"
TRUST_PROXY="1"
LOG_HTTP_REQUESTS="1"
LOG_FORMAT="json"
APP_VERSION="0.1.0"
GIT_SHA=""

# Seguridad / CORS (sin localhost en producción)
CORS_ORIGINS="https://tu-dominio.com,https://www.tu-dominio.com"

# SMTP (recomendado para producción)
SMTP_HOST="smtp.tu-proveedor.com"
SMTP_PORT="587"
SMTP_USER="usuario_smtp"
SMTP_PASS="clave_smtp"
SMTP_SECURE="0"

# Seguridad runtime (recomendado)
MAIL_PREVIEW_TOKENS="0"
ALLOW_ADMIN_BOOTSTRAP="0"
ALLOW_DEMO_SEED="0"

# Bootstrap admin (desactivado o rotado en producción)
ADMIN_BOOTSTRAP_KEY=""

# WhatsApp Cloud API (Meta)
WHATSAPP_CLOUD_ENABLED="1"
WHATSAPP_CLOUD_ACCESS_TOKEN=""
WHATSAPP_CLOUD_PHONE_NUMBER_ID=""
WHATSAPP_CLOUD_VERIFY_TOKEN=""
WHATSAPP_CLOUD_API_VERSION="v23.0"
WHATSAPP_CLOUD_BASE_URL="https://graph.facebook.com"
