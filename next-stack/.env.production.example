# PostgreSQL (producción / staging)
DATABASE_URL="postgresql://USUARIO:CLAVE@HOST:5432/nico_reparaciones_next?schema=public"

# JWT/Auth (NestJS) - usar secretos largos y únicos (32+ chars)
JWT_ACCESS_SECRET="REEMPLAZAR_CON_SECRET_LARGO_Y_UNICO_32+"
JWT_REFRESH_SECRET="REEMPLAZAR_CON_SECRET_LARGO_Y_UNICO_32+"

# URLs reales (usar HTTPS)
WEB_URL="https://tu-dominio.com"
API_URL="https://api.tu-dominio.com"
VITE_API_URL="https://api.tu-dominio.com"
HOST="0.0.0.0"
PORT="3001"
TRUST_PROXY="1"
LOG_HTTP_REQUESTS="1"
LOG_FORMAT="json"
APP_VERSION="0.1.0"
GIT_SHA=""

# Seguridad / CORS (sin localhost en producción)
CORS_ORIGINS="https://tu-dominio.com,https://www.tu-dominio.com"

# SMTP (recomendado para producción)
SMTP_HOST="smtp.tu-proveedor.com"
SMTP_PORT="587"
SMTP_USER="usuario_smtp"
SMTP_PASS="clave_smtp"
SMTP_SECURE="0"

# Seguridad runtime (recomendado)
MAIL_PREVIEW_TOKENS="0"
ALLOW_ADMIN_BOOTSTRAP="0"
ALLOW_DEMO_SEED="0"

# Bootstrap admin (desactivado o rotado en producción)
ADMIN_BOOTSTRAP_KEY=""
