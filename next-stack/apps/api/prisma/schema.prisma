generator client {
  provider = "prisma-client-js"
  output   = "../../../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum OrderStatus {
  PENDIENTE
  CONFIRMADO
  PREPARANDO
  LISTO_RETIRO
  ENTREGADO
  CANCELADO
}

enum RepairStatus {
  RECEIVED
  DIAGNOSING
  WAITING_APPROVAL
  REPAIRING
  READY_PICKUP
  DELIVERED
  CANCELLED
}

model User {
  id                      String                   @id @default(cuid())
  name                    String
  email                   String                   @unique
  passwordHash            String?
  role                    UserRole                 @default(USER)
  emailVerified           Boolean                  @default(false)
  emailVerifiedAt         DateTime?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  orders                  Order[]
  repairs                 Repair[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
  refreshTokens           RefreshToken[]
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId     String
  tokenHash  String   @unique
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId     String
  tokenHash  String   @unique
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model RefreshToken {
  id         String   @id @default(cuid())
  userId      String
  tokenHash   String   @unique
  expiresAt   DateTime
  revokedAt   DateTime?
  replacedById String?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Category {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  active    Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]
}

model Product {
  id          String      @id @default(cuid())
  name        String
  slug        String      @unique
  description String?
  price       Decimal     @db.Decimal(12, 2)
  costPrice   Decimal?    @db.Decimal(12, 2)
  stock       Int         @default(0)
  active      Boolean     @default(true)
  featured    Boolean     @default(false)
  sku         String?     @unique
  barcode     String?     @unique
  categoryId  String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  category    Category?   @relation(fields: [categoryId], references: [id])
  orderItems   OrderItem[]
}

model Order {
  id              String       @id @default(cuid())
  userId          String?
  status          OrderStatus  @default(PENDIENTE)
  total           Decimal      @db.Decimal(12, 2)
  paymentMethod   String?
  isQuickSale     Boolean      @default(false)
  quickSaleAdminId String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  user            User?        @relation(fields: [userId], references: [id])
  items           OrderItem[]
}

model OrderItem {
  id         String   @id @default(cuid())
  orderId     String
  productId   String?
  nameSnapshot String
  unitPrice   Decimal  @db.Decimal(12, 2)
  quantity    Int
  lineTotal   Decimal  @db.Decimal(12, 2)
  createdAt   DateTime @default(now())
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product? @relation(fields: [productId], references: [id])
}

model Repair {
  id            String       @id @default(cuid())
  userId        String?
  deviceBrandId String?
  deviceModelId String?
  deviceIssueTypeId String?
  customerName  String
  customerPhone String?
  deviceBrand   String?
  deviceModel   String?
  issueLabel    String?
  status        RepairStatus @default(RECEIVED)
  quotedPrice   Decimal?     @db.Decimal(12, 2)
  finalPrice    Decimal?     @db.Decimal(12, 2)
  notes         String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  user          User?        @relation(fields: [userId], references: [id])
  events        RepairEventLog[]

  @@index([deviceBrandId])
  @@index([deviceModelId])
  @@index([deviceIssueTypeId])
}

model RepairEventLog {
  id        String   @id @default(cuid())
  repairId   String
  eventType String
  message   String?
  metaJson  String?
  createdAt DateTime @default(now())
  repair    Repair    @relation(fields: [repairId], references: [id], onDelete: Cascade)

  @@index([repairId, createdAt])
  @@index([eventType])
}

model RepairPricingRule {
  id            String   @id @default(cuid())
  name          String
  active        Boolean  @default(true)
  priority      Int      @default(0)
  deviceBrandId String?
  deviceModelId String?
  deviceIssueTypeId String?
  deviceBrand   String?
  deviceModel   String?
  issueLabel    String?
  basePrice     Decimal  @db.Decimal(12, 2)
  profitPercent Decimal  @db.Decimal(7, 2) @default(0)
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([active, priority])
  @@index([deviceBrandId])
  @@index([deviceModelId])
  @@index([deviceIssueTypeId])
}

model DeviceBrand {
  id        String        @id @default(cuid())
  name      String
  slug      String        @unique
  active    Boolean       @default(true)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  models    DeviceModel[]

  @@index([active])
}

model DeviceModel {
  id         String      @id @default(cuid())
  brandId    String
  name       String
  slug       String
  active     Boolean     @default(true)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  brand      DeviceBrand @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@unique([brandId, slug])
  @@index([brandId, active])
}

model DeviceIssueType {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active])
}

model AppSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String?
  group     String   @default("general")
  label     String?
  type      String   @default("text")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([group])
}

model WhatsAppLog {
  id         String   @id @default(cuid())
  channel    String   @default("general")
  templateKey String?
  targetType String?
  targetId    String?
  phone      String?
  recipient  String?
  status     String   @default("SENT")
  message    String?
  metaJson   String?
  createdAt  DateTime @default(now())

  @@index([channel, createdAt])
  @@index([templateKey])
  @@index([targetType, targetId])
}

model HelpFaqItem {
  id        String   @id @default(cuid())
  question  String
  answer    String
  category  String?  @default("general")
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active, sortOrder])
  @@index([category])
}
