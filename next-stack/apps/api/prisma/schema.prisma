generator client {
  provider = "prisma-client-js"
  output   = "../../../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum OrderStatus {
  PENDIENTE
  CONFIRMADO
  PREPARANDO
  LISTO_RETIRO
  ENTREGADO
  CANCELADO
}

enum RepairStatus {
  RECEIVED
  DIAGNOSING
  WAITING_APPROVAL
  REPAIRING
  READY_PICKUP
  DELIVERED
  CANCELLED
}

enum RepairPricingSnapshotSource {
  RULE_ONLY
  SUPPLIER_PART
  MANUAL_OVERRIDE
}

enum RepairPricingSnapshotStatus {
  DRAFT
  APPLIED
  SUPERSEDED
  DISCARDED
}

model User {
  id                      String                   @id @default(cuid())
  name                    String
  email                   String                   @unique
  googleSubject           String?                  @unique
  passwordHash            String?
  role                    UserRole                 @default(USER)
  emailVerified           Boolean                  @default(false)
  emailVerifiedAt         DateTime?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  orders                  Order[]
  repairs                 Repair[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
  refreshTokens           RefreshToken[]
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model RefreshToken {
  id           String    @id @default(cuid())
  userId       String
  tokenHash    String    @unique
  expiresAt    DateTime
  revokedAt    DateTime?
  replacedById String?
  createdAt    DateTime  @default(now())
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Category {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  active    Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]
  productPricingRules ProductPricingRule[]
}

model Product {
  id          String      @id @default(cuid())
  name        String
  slug        String      @unique
  description String?
  imageLegacy String?     @map("image")
  imagePath   String?     @map("image_path")
  price       Decimal     @db.Decimal(12, 2)
  costPrice   Decimal?    @db.Decimal(12, 2)
  purchaseReference String? @map("purchase_reference")
  stock       Int         @default(0)
  active      Boolean     @default(true)
  featured    Boolean     @default(false)
  sku         String?     @unique
  barcode     String?     @unique
  categoryId  String?
  supplierId  String?     @map("supplier_id")
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  category    Category?   @relation(fields: [categoryId], references: [id])
  supplier    Supplier?   @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  orderItems  OrderItem[]
  productPricingRules ProductPricingRule[]

  @@index([supplierId])
}

model ProductPricingRule {
  id           String    @id @default(cuid())
  name         String
  categoryId   String?
  productId    String?
  costMin      Int?
  costMax      Int?
  marginPercent Decimal  @default(30) @db.Decimal(7, 2)
  priority     Int       @default(0)
  active       Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  category     Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  product      Product?  @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([active, categoryId, productId, priority])
  @@index([costMin, costMax])
}

model Order {
  id               String      @id @default(cuid())
  userId           String?
  status           OrderStatus @default(PENDIENTE)
  total            Decimal     @db.Decimal(12, 2)
  paymentMethod    String?
  isQuickSale      Boolean     @default(false)
  quickSaleAdminId String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  user             User?       @relation(fields: [userId], references: [id])
  items            OrderItem[]
}

model OrderItem {
  id           String   @id @default(cuid())
  orderId      String
  productId    String?
  nameSnapshot String
  unitPrice    Decimal  @db.Decimal(12, 2)
  quantity     Int
  lineTotal    Decimal  @db.Decimal(12, 2)
  createdAt    DateTime @default(now())
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product      Product? @relation(fields: [productId], references: [id])
}

model Repair {
  id                String           @id @default(cuid())
  userId            String?
  deviceTypeId      String?
  deviceBrandId     String?
  deviceModelId     String?
  deviceIssueTypeId String?
  activePricingSnapshotId String?          @unique
  customerName      String
  customerPhone     String?
  deviceBrand       String?
  deviceModel       String?
  issueLabel        String?
  status            RepairStatus     @default(RECEIVED)
  quotedPrice       Decimal?         @db.Decimal(12, 2)
  finalPrice        Decimal?         @db.Decimal(12, 2)
  notes             String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  user              User?            @relation(fields: [userId], references: [id])
  deviceType        DeviceType?      @relation(fields: [deviceTypeId], references: [id])
  events            RepairEventLog[]
  activePricingSnapshot RepairPricingSnapshot? @relation("RepairActivePricingSnapshot", fields: [activePricingSnapshotId], references: [id], onDelete: SetNull)
  pricingSnapshots  RepairPricingSnapshot[] @relation("RepairPricingSnapshots")

  @@index([deviceTypeId])
  @@index([deviceBrandId])
  @@index([deviceModelId])
  @@index([deviceIssueTypeId])
  @@index([activePricingSnapshotId])
}

model RepairEventLog {
  id        String   @id @default(cuid())
  repairId  String
  eventType String
  message   String?
  metaJson  String?
  createdAt DateTime @default(now())
  repair    Repair   @relation(fields: [repairId], references: [id], onDelete: Cascade)

  @@index([repairId, createdAt])
  @@index([eventType])
}

model RepairPricingRule {
  id                 String            @id @default(cuid())
  name               String
  active             Boolean           @default(true)
  priority           Int               @default(0)
  deviceTypeId       String?
  deviceBrandId      String?
  deviceModelGroupId String?
  deviceModelId      String?
  deviceIssueTypeId  String?
  deviceBrand        String?
  deviceModel        String?
  issueLabel         String?
  basePrice          Decimal           @db.Decimal(12, 2)
  profitPercent      Decimal           @default(0) @db.Decimal(7, 2)
  calcMode           String            @default("BASE_PLUS_MARGIN")
  minProfit          Decimal?          @db.Decimal(12, 2)
  minFinalPrice      Decimal?          @db.Decimal(12, 2)
  shippingFee        Decimal?          @db.Decimal(12, 2)
  notes              String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  deviceType         DeviceType?       @relation(fields: [deviceTypeId], references: [id])
  modelGroup         DeviceModelGroup? @relation(fields: [deviceModelGroupId], references: [id])
  pricingSnapshots   RepairPricingSnapshot[]

  @@index([active, priority])
  @@index([deviceTypeId])
  @@index([deviceBrandId])
  @@index([deviceModelGroupId])
  @@index([deviceModelId])
  @@index([deviceIssueTypeId])
}

model RepairPricingSnapshot {
  id                        String                      @id @default(cuid())
  repairId                  String
  pricingRuleId             String?
  source                    RepairPricingSnapshotSource @default(SUPPLIER_PART)
  status                    RepairPricingSnapshotStatus @default(DRAFT)
  supplierId                String?
  supplierNameSnapshot      String?
  supplierSearchQuery       String?
  supplierEndpointSnapshot  String?
  externalPartId            String?
  partSkuSnapshot           String?
  partNameSnapshot          String
  partBrandSnapshot         String?
  partUrlSnapshot           String?
  partAvailabilitySnapshot  String?
  quantity                  Int                         @default(1)
  deviceTypeIdSnapshot      String?
  deviceBrandIdSnapshot     String?
  deviceModelGroupIdSnapshot String?
  deviceModelIdSnapshot     String?
  deviceIssueTypeIdSnapshot String?
  deviceBrandSnapshot       String?
  deviceModelSnapshot       String?
  issueLabelSnapshot        String?
  baseCost                  Decimal                     @db.Decimal(12, 2)
  extraCost                 Decimal?                    @db.Decimal(12, 2)
  shippingCost              Decimal?                    @db.Decimal(12, 2)
  pricingRuleNameSnapshot   String?
  calcModeSnapshot          String?
  marginPercentSnapshot     Decimal?                    @db.Decimal(7, 2)
  minProfitSnapshot         Decimal?                    @db.Decimal(12, 2)
  minFinalPriceSnapshot     Decimal?                    @db.Decimal(12, 2)
  shippingFeeSnapshot       Decimal?                    @db.Decimal(12, 2)
  suggestedQuotedPrice      Decimal?                    @db.Decimal(12, 2)
  appliedQuotedPrice        Decimal?                    @db.Decimal(12, 2)
  manualOverridePrice       Decimal?                    @db.Decimal(12, 2)
  createdAt                 DateTime                    @default(now())
  updatedAt                 DateTime                    @updatedAt
  appliedAt                 DateTime?
  repair                    Repair                      @relation("RepairPricingSnapshots", fields: [repairId], references: [id], onDelete: Cascade)
  pricingRule               RepairPricingRule?          @relation(fields: [pricingRuleId], references: [id], onDelete: SetNull)
  supplier                  Supplier?                   @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  activeForRepair           Repair?                     @relation("RepairActivePricingSnapshot")

  @@index([repairId, createdAt])
  @@index([status])
  @@index([source])
  @@index([supplierId])
  @@index([pricingRuleId])
}

model DeviceBrand {
  id           String             @id @default(cuid())
  deviceTypeId String?
  name         String
  slug         String             @unique
  active       Boolean            @default(true)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  deviceType   DeviceType?        @relation(fields: [deviceTypeId], references: [id])
  models       DeviceModel[]
  modelGroups  DeviceModelGroup[]

  @@index([active])
  @@index([deviceTypeId])
}

model DeviceModel {
  id                 String            @id @default(cuid())
  brandId            String
  deviceModelGroupId String?
  name               String
  slug               String
  active             Boolean           @default(true)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  brand              DeviceBrand       @relation(fields: [brandId], references: [id], onDelete: Cascade)
  modelGroup         DeviceModelGroup? @relation(fields: [deviceModelGroupId], references: [id], onDelete: SetNull)

  @@unique([brandId, slug])
  @@index([brandId, active])
  @@index([deviceModelGroupId])
}

model DeviceIssueType {
  id           String      @id @default(cuid())
  deviceTypeId String?
  name         String
  slug         String      @unique
  active       Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  deviceType   DeviceType? @relation(fields: [deviceTypeId], references: [id])

  @@index([active])
  @@index([deviceTypeId])
}

model DeviceType {
  id                 String              @id @default(cuid())
  name               String
  slug               String              @unique
  active             Boolean             @default(true)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  brands             DeviceBrand[]
  issues             DeviceIssueType[]
  repairPricingRules RepairPricingRule[]
  repairs            Repair[]

  @@index([active])
}

model DeviceModelGroup {
  id                 String              @id @default(cuid())
  deviceBrandId      String
  name               String
  slug               String
  active             Boolean             @default(true)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  brand              DeviceBrand         @relation(fields: [deviceBrandId], references: [id], onDelete: Cascade)
  models             DeviceModel[]
  repairPricingRules RepairPricingRule[]

  @@unique([deviceBrandId, slug])
  @@index([deviceBrandId, active])
}

model Supplier {
  id               String             @id @default(cuid())
  name             String             @unique
  phone            String?
  notes            String?
  active           Boolean            @default(true)
  searchPriority   Int                @default(100)
  searchEnabled    Boolean            @default(false)
  searchInRepairs  Boolean            @default(false)
  searchMode       String             @default("html")
  searchEndpoint   String?
  searchConfigJson String?
  lastProbeStatus  String?
  lastProbeQuery   String?
  lastProbeCount   Int                @default(0)
  lastProbeError   String?
  lastProbeAt      DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  products         Product[]
  repairPricingSnapshots RepairPricingSnapshot[]
  incidents        WarrantyIncident[]

  @@index([active, searchPriority])
}

model WarrantyIncident {
  id              String    @id @default(cuid())
  sourceType      String
  status          String    @default("open")
  title           String
  reason          String?
  repairId        String?
  productId       String?
  orderId         String?
  supplierId      String?
  quantity        Int       @default(1)
  unitCost        Decimal   @db.Decimal(12, 2)
  costOrigin      String    @default("manual")
  extraCost       Decimal   @default(0) @db.Decimal(12, 2)
  recoveredAmount Decimal   @default(0) @db.Decimal(12, 2)
  lossAmount      Decimal   @default(0) @db.Decimal(12, 2)
  happenedAt      DateTime
  resolvedAt      DateTime?
  notes           String?
  createdBy       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  supplier        Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)

  @@index([status, happenedAt])
  @@index([sourceType])
  @@index([supplierId])
  @@index([repairId])
  @@index([productId])
  @@index([orderId])
}

model AppSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String?
  group     String   @default("general")
  label     String?
  type      String   @default("text")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([group])
}

model WhatsAppLog {
  id          String   @id @default(cuid())
  channel     String   @default("general")
  templateKey String?
  targetType  String?
  targetId    String?
  phone       String?
  recipient   String?
  provider    String?
  remoteMessageId String? @unique
  providerStatus String?
  errorMessage String?
  status      String   @default("PENDING")
  message     String?
  metaJson    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  lastAttemptAt DateTime?
  sentAt      DateTime?
  failedAt    DateTime?

  @@index([channel, createdAt])
  @@index([templateKey])
  @@index([targetType, targetId])
  @@index([status, createdAt])
  @@index([providerStatus, createdAt])
}

model HelpFaqItem {
  id        String   @id @default(cuid())
  question  String
  answer    String
  category  String?  @default("general")
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active, sortOrder])
  @@index([category])
}
