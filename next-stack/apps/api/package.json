{
  "name": "@nico/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "build:prod": "npm run build",
    "start": "node dist/main.js",
    "start:prod": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "db:generate": "dotenv -e ../../.env -- prisma generate",
    "db:check": "dotenv -e ../../.env -- tsx prisma/db-check.ts",
    "db:migrate": "dotenv -e ../../.env -- prisma migrate dev",
    "db:migrate:deploy": "dotenv -e ../../.env -- prisma migrate deploy",
    "db:push": "dotenv -e ../../.env -- prisma db push",
    "db:push:skip-generate": "dotenv -e ../../.env -- prisma db push --skip-generate",
    "db:studio": "dotenv -e ../../.env -- prisma studio",
    "db:seed": "dotenv -e ../../.env -- tsx prisma/seed.ts",
    "db:seed:demo": "dotenv -e ../../.env -- tsx prisma/seed.ts",
    "db:migrate:legacy-settings": "dotenv -e ../../.env -- tsx prisma/migrate-legacy-settings.ts",
    "db:migrate:legacy-settings:cleanup": "dotenv -e ../../.env -- tsx prisma/migrate-legacy-settings.ts --cleanup",
    "db:migrate:product-images": "dotenv -e ../../.env -- tsx prisma/migrate-legacy-product-images.ts",
    "db:migrate:product-images:dry-run": "dotenv -e ../../.env -- tsx prisma/migrate-legacy-product-images.ts --dry-run",
    "db:migrate:product-images:cleanup-legacy": "dotenv -e ../../.env -- tsx prisma/migrate-legacy-product-images.ts --cleanup-legacy",
    "db:migrate:visual-assets": "dotenv -e ../../.env -- tsx prisma/migrate-legacy-visual-assets.ts",
    "db:migrate:visual-assets:dry-run": "dotenv -e ../../.env -- tsx prisma/migrate-legacy-visual-assets.ts --dry-run"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.6",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.6",
    "@nestjs/jwt": "^11.0.1",
    "@nestjs/platform-express": "^11.1.6",
    "@nestjs/throttler": "^6.5.0",
    "@nico/contracts": "*",
    "@prisma/client": "^6.16.2",
    "bcryptjs": "^3.0.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "dotenv": "^17.2.3",
    "helmet": "^8.1.0",
    "nodemailer": "^8.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^24.3.0",
    "@types/nodemailer": "^7.0.11",
    "dotenv-cli": "^11.0.0",
    "dotenv-cli": "^7.4.4",
    "prisma": "^6.16.2",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
